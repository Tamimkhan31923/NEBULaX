{
  "root": true,
  "env": { "browser": true, "es2023": true },
  "parserOptions": { "ecmaVersion": 2023, "sourceType": "module" },
  "extends": "eslint:recommended",
  "rules": {
    "no-unused-vars": ["warn", { "argsIgnorePattern": "^_" }],
    "no-console": ["warn", { "allow": ["warn", "error"] }],
    "prefer-const": "error",
    "eqeqeq": ["error", "always"],
    "no-var": "error"
  }
}
